<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/functional_card_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <ImageView
        android:id="@+id/functional_card_background_image"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:visibility="visible" />

    <ImageView
        android:id="@+id/functional_card_icon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        app:layout_constraintBottom_toBottomOf="@+id/functional_card_text_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/functional_card_text_container"
        android:layout_marginStart="16dp"
        android:layout_marginTop="0dp"
        app:tint="@color/card_darkgreen"
        tools:src="@drawable/icon_for_none" />

    <LinearLayout
        android:id="@+id/functional_card_text_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="28dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toStartOf="@+id/functional_card_interaction_frame"
        app:layout_constraintStart_toEndOf="@id/functional_card_icon"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/functional_card_text_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#333333"
            android:textSize="17sp"
            android:textStyle="bold"
            tools:text="个性化" />

        <TextView
            android:id="@+id/functional_card_summary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#666666"
            android:textSize="13sp"
            tools:text="自定义应用外观和主题" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/functional_card_interaction_frame"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="@+id/functional_card_text_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/functional_card_text_container">

        <ImageView
            android:id="@+id/functional_card_mode_arrow"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center"
            android:alpha="0.4"
            android:layout_marginEnd="16dp"
            android:src="@drawable/right_arrow"
            android:visibility="gone" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/functional_card_mode_switch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="visible"
            android:textOn=""
            android:textOff=""
            android:layout_marginEnd="16dp"
            app:showText="false"
            app:thumbTint="@color/white"
            app:trackDecorationTint="@color/card_darkgreen"
            app:trackTint="@color/card_darkgreen" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/functional_card_mode_slider_group"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/functional_card_text_container"
        app:layout_constraintStart_toStartOf="@id/functional_card_text_container"
        app:layout_constraintEnd_toEndOf="parent"
        tools:visibility="visible">

        <TextView
            android:id="@+id/functional_card_tv_min"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#999999"
            android:textSize="12sp"
            tools:text="0" />

        <com.google.android.material.slider.Slider
            android:id="@+id/functional_card_slider"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:layout_weight="1"
            android:valueFrom="0.0"
            android:valueTo="100.0" />

        <TextView
            android:id="@+id/functional_card_tv_max"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#999999"
            android:textSize="12sp"
            tools:text="100" />
    </LinearLayout>

    <Space
        android:id="@+id/functional_card_bottom_space"
        android:layout_width="0dp"
        android:layout_height="16dp"
        app:layout_constraintTop_toBottomOf="@id/functional_card_mode_slider_group"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>