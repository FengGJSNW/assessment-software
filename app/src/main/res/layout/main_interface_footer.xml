<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:id="@+id/bottom_nav_wrapper"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <!--        全局背景-->
        <View
            android:id="@+id/bottom_blur_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#4DFFFFFF" />

        <!--        顶部的小细线-->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#1A000000" />

<!--        选项布局-->
        <LinearLayout
            android:id="@+id/bottom_nav_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:orientation="horizontal">

<!--            技能规划-->
            <LinearLayout
                android:id="@+id/footer_skill_study"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:duplicateParentState="true"
                    android:src="@drawable/plan"
                    app:tint="@color/nav_item_color_selector" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="技能规划"
                    android:textSize="12sp" />
            </LinearLayout>

<!--            心得沉淀-->
            <LinearLayout
                android:id="@+id/footer_notes"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:duplicateParentState="true"
                    android:src="@drawable/pencil"
                    app:tint="@color/nav_item_color_selector" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="心得沉淀"
                    android:textSize="12sp" />
            </LinearLayout>

<!--            AI分析-->
            <LinearLayout
                android:id="@+id/footer_ai"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:duplicateParentState="true"
                    android:src="@drawable/chatgpt"
                    app:tint="@color/nav_item_color_selector" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI分析"
                    android:textSize="12sp" />
            </LinearLayout>

<!--            生活便利-->
            <LinearLayout
                android:id="@+id/footer_life"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:duplicateParentState="true"
                    android:src="@drawable/coffee"
                    app:tint="@color/nav_item_color_selector" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="生活便利"
                    android:textSize="12sp" />
            </LinearLayout>

<!--            设置-->
            <LinearLayout
                android:id="@+id/footer_settings"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:duplicateParentState="true"
                    android:src="@drawable/settings"
                    app:tint="@color/nav_item_color_selector" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="设置"
                    android:textSize="12sp" />
            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>