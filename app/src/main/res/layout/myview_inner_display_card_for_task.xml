<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:paddingHorizontal="16dp"
    android:paddingVertical="14dp">

    <ImageView
        android:id="@+id/internal_icon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/point"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/black" />

    <LinearLayout
        android:id="@+id/internal_main_info_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:orientation="vertical"
        app:layout_constraintStart_toEndOf="@id/internal_icon"
        app:layout_constraintEnd_toStartOf="@id/internal_date_container"
        app:layout_constraintTop_toTopOf="@id/internal_icon">

        <TextView
            android:id="@+id/internal_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="@font/harmonyos_sans_bold"
            android:maxLines="1"
            android:textColor="#222222"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="高等数学错题整理" />

        <TextView
            android:id="@+id/internal_date_range"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#888888"
            android:textSize="12sp"
            tools:text="2026-04-15 ~ 2026-04-20" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/internal_date_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/internal_main_info_container">

        <TextView
            android:id="@+id/internal_start_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#999999"
            android:textSize="12sp"
            tools:text="开始 04/15" />

        <TextView
            android:id="@+id/internal_end_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#999999"
            android:textSize="12sp"
            tools:text="结束 04/20" />
    </LinearLayout>

    <TextView
        android:id="@+id/internal_summary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="4dp"
        android:ellipsize="end"
        android:maxLines="3"
        android:textColor="#555555"
        android:textSize="13sp"
        app:layout_constraintStart_toStartOf="@id/internal_main_info_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/internal_main_info_container"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:text="完成高数第 3 章错题整理，并补充例题笔记，整理到错题本中。" />

</androidx.constraintlayout.widget.ConstraintLayout>