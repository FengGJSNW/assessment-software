<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/main_interface_background">

    <!-- 上方：可滚动内容区 -->
    <com.example.xiaomingassistant.ui.view.TopBarWithScrollView
        android:id="@+id/ai_content_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/input_bar"
        app:titleText="AI助手">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">


            <!-- AI消息 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:gravity="start"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_marginTop="4dp"
                    android:src="@drawable/personalized"
                    android:tint="@color/card_darkgreen"
                    tools:ignore="ContentDescription" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#D8EBDD"
                    app:strokeWidth="2dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:maxWidth="260dp"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="14dp"
                        android:text="你好，我是你的 AI 助手。今天想让我帮你整理什么内容？"
                        android:textColor="#222222"
                        android:textSize="15sp"
                        tools:ignore="HardcodedText" />

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- 用户消息 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:gravity="end"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#EAF7F1"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/card_darkgreen"
                    app:strokeWidth="2dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:maxWidth="260dp"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="14dp"
                        android:text="帮我总结一下最近关于 Fragment 生命周期的学习心得。"
                        android:textColor="#222222"
                        android:textSize="15sp"
                        tools:ignore="HardcodedText" />

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- AI回复 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:gravity="start"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_marginTop="4dp"
                    android:src="@drawable/personalized"
                    android:tint="@color/card_darkgreen"
                    tools:ignore="ContentDescription" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#D8EBDD"
                    app:strokeWidth="2dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:maxWidth="260dp"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="14dp"
                        android:text="可以总结为三点：第一，Fragment 的视图生命周期和 Fragment 本身生命周期不同；第二，ViewBinding 更适合在 onCreateView 到 onDestroyView 之间使用；第三，页面逻辑建议尽量放在 onViewCreated 中处理。"
                        android:textColor="#222222"
                        android:textSize="15sp"
                        tools:ignore="HardcodedText" />

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- 给底部输入栏留一点视觉空间 -->
            <Space
                android:layout_width="match_parent"
                android:layout_height="12dp" />

        </LinearLayout>

    </com.example.xiaomingassistant.ui.view.TopBarWithScrollView>

    <!-- 下方：固定输入栏 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/input_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="12dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/card_darkgreen"
        app:strokeWidth="3dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="14dp">

            <EditText
                android:id="@+id/ai_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="输入你想问的问题"
                android:minHeight="48dp"
                android:paddingHorizontal="8dp"
                android:textColor="#222222"
                android:textColorHint="#999999"
                android:textSize="15sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_send_ai"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text=""
                app:backgroundTint="@color/card_darkgreen"
                app:cornerRadius="14dp"
                app:icon="@drawable/personalized"
                app:iconTint="@android:color/white" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>