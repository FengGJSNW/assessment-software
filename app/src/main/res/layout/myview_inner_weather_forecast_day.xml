<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="18dp"
    android:paddingVertical="14dp">

    <LinearLayout
        android:id="@+id/weather_forecast_date_group"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/weather_forecast_weather_group"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.28">

        <TextView
            android:id="@+id/weather_forecast_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:textColor="@color/white_alpha100"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="04/26" />

        <TextView
            android:id="@+id/weather_forecast_week"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:includeFontPadding="false"
            android:textColor="@color/white_alpha70"
            android:textSize="12sp"
            tools:text="周日" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/weather_forecast_weather_group"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/weather_forecast_temp_group"
        app:layout_constraintStart_toEndOf="@id/weather_forecast_date_group"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/weather_forecast_weather"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:textColor="@color/white_alpha100"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="晴转多云" />

        <TextView
            android:id="@+id/weather_forecast_wind"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:textColor="@color/white_alpha70"
            android:textSize="12sp"
            tools:text="西南风 3~4级" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/weather_forecast_temp_group"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/weather_forecast_temp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:textColor="@color/white_alpha100"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="12° / 7°" />

        <TextView
            android:id="@+id/weather_forecast_temp_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:includeFontPadding="false"
            android:text="白天 / 夜间"
            android:textColor="@color/white_alpha70"
            android:textSize="12sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
