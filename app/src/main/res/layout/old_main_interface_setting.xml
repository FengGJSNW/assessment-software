<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/main_interface_background">

    <!--    设置滑动区域-->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/skillstudy_scrollview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/skillstudy_content_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="20dp"
            android:paddingTop="80dp">

            <TextView
                android:id="@+id/tv_main_large_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:fontFamily="@font/harmonyos_sans_bold"
                android:text="设置"
                android:textColor="#333333"
                android:textSize="36sp"
                tools:ignore="HardcodedText" />


            <!--个性化-->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/card_darkgreen"
                app:strokeWidth="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.example.xiaomingassistant.ui.view.MySettingCard
                        android:id="@+id/settings_card_personalized"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:customImage="@drawable/personalized"
                        app:customMode="jump"
                        app:customTitle="个性化"
                        app:customText="自定义某些图片" />

                    <com.example.xiaomingassistant.ui.view.MySettingCard
                        android:id="@+id/settings_card_night"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:customImage="@drawable/personalized"
                        app:customMode="toggle"
                        app:customTitle="夜间模式"
                        app:customText="使用暗色防止在黑暗环境损害眼睛" />

                    <com.example.xiaomingassistant.ui.view.MySettingCard
                        android:id="@+id/settings_card_fontsize"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:customImage="@drawable/personalized"
                        app:customMode="slider"
                        app:customTitle="文字大小"
                        app:customText="滑动滑动条更改字体大小" />


                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!--权限-->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/card_darkgreen"
                app:strokeWidth="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.example.xiaomingassistant.ui.view.MySettingCard
                        android:id="@+id/settings_card_power"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:customImage="@drawable/personalized"
                        app:customMode="jump"
                        app:customTitle="权限"
                        app:customText="获取某些必要的权限" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!--关于-->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/card_darkgreen"
                app:strokeWidth="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.example.xiaomingassistant.ui.view.MySettingCard
                        android:id="@+id/settings_card_about"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:customImage="@drawable/personalized"
                        app:customMode="jump"
                        app:customTitle="关于"
                        app:customText="来看看作者吧" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/card_darkgreen"
                app:strokeWidth="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="1000dp"
                    android:orientation="vertical">

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>



        </LinearLayout>

    </androidx.core.widget.NestedScrollView>


    <!--顶栏-->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/top_bar_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:elevation="10dp"
        app:layout_constraintTop_toTopOf="parent">

        <com.example.xiaomingassistant.ui.view.RealtimeBlurView.RealtimeBlurView
            android:id="@+id/top_bar_blur_bg"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:realtimeBlurRadius="20dp"
            app:realtimeOverlayColor="#4DFFFFFF" />

        <TextView
            android:id="@+id/skillstudy_topbar"
            android:layout_width="wrap_content"
            android:layout_height="60dp"
            android:gravity="center"
            android:text="设置"
            android:textColor="#000000"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            tools:ignore="HardcodedText" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>